{
  "name": "radmapping-plus-tooling",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "prepare": "git config core.hooksPath RadMapping+/.husky/_",
    "format": "pnpm run format:prettier && pnpm run format:python",
    "format:prettier": "prettier --write . --ignore-unknown",
    "format:python": "python -m ruff format .",
    "format:check": "pnpm run format:check:prettier && pnpm run format:check:python",
    "format:check:prettier": "prettier --check . --ignore-unknown",
    "format:check:python": "python -m ruff format --check .",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "**/*.{md,json,yml,yaml,css}": "pnpm exec prettier --write",
    "**/*.py": "python -m ruff format"
  }
}
